# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=<project-id>
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=TRUE
VERTEXAI_PROJECT=<project-id>
VERTEXAI_LOCATION=global

# Agent Model
AGENT_MODEL=gemini-2.5-flash
# AGENT_MODEL=gemini-2.5-pro

# Salesforce OAuth (Connected App)
# Connected App must have "Require Secret for Web Server Flow" enabled
SALESFORCE_CLIENT_ID=<connected-app-consumer-key>
SALESFORCE_CLIENT_SECRET=<connected-app-consumer-secret>
SALESFORCE_LOGIN_URL=https://login.salesforce.com
# SALESFORCE_LOGIN_URL=https://<org>.sandbox.my.salesforce.com
SALESFORCE_INSTANCE_URL=https://<instance>.my.salesforce.com
SALESFORCE_API_VERSION=65.0

# Timezone
AGENT_TIMEZONE=Asia/Seoul

# Agentspace Mode
# Set SALESFORCE_AUTH_ID to enable Agentspace mode (platform injects OAuth token)
# Comment out for local dev (adk web) to use standard Authorization Code Flow
# SALESFORCE_AUTH_ID=<agentspace-auth-config-name>
AGENTSPACE_MODE=false

# Agent Engine Deployment
STAGING_BUCKET=gs://<project-id>-adk-staging
# AGENT_DISPLAY_NAME=Salesforce Agent
# AGENT_DESCRIPTION=Salesforce specialist agent
# AGENT_RESOURCE_NAME=projects/<project-number>/locations/<location>/reasoningEngines/<id>
# GCS_DIR_NAME=production
# AGENT_LABELS={"env": "production"}
# AGENT_MIN_INSTANCES=0
# AGENT_MAX_INSTANCES=1

# Logging
LOG_LEVEL=INFO
SALESFORCE_AGENT_LOG_LEVEL=INFO
GOOGLE_ADK_LOG_LEVEL=INFO

# Observability (optional)
# GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
